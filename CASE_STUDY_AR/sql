invoice overall view
  
SELECT
    invoice_id,
    invoice_date,
    due_date,
    amount,
    status
FROM INVOICES
ORDER BY invoice_date;

Párování faktur a plateb
SELECT
    i.invoice_id,
    i.invoice_date,
    p.payment_id,
    p.payment_date,
    ca.applied_amount
FROM INVOICES i
JOIN CASH_APPLICATIONS ca
    ON ca.invoice_id = i.invoice_id
JOIN PAYMENTS p
    ON p.payment_id = ca.payment_id
ORDER BY i.invoice_date;


non-allocated payments
  
SELECT
    p.payment_id,
    p.customer_id,
    p.payment_date,
    p.amount,
    p.reference,
    p.method
FROM PAYMENTS p
LEFT JOIN CASH_APPLICATIONS ca
    ON ca.payment_id = p.payment_id
WHERE ca.payment_id IS NULL
ORDER BY p.amount DESC;


Podezřelé platby před vystavením faktury
SELECT
    i.invoice_id,
    i.invoice_date,
    p.payment_id,
    p.payment_date,
    ca.applied_amount
FROM INVOICES i
JOIN CASH_APPLICATIONS ca
    ON ca.invoice_id = i.invoice_id
JOIN PAYMENTS p
    ON p.payment_id = ca.payment_id
WHERE p.payment_date < i.invoice_date
ORDER BY p.payment_date;


Dny do zaplacení
SELECT
    i.invoice_id,
    i.invoice_date,
    p.payment_date,
    CAST(julianday(p.payment_date) - julianday(i.invoice_date) AS INTEGER) AS days_to_pay
FROM INVOICES i
JOIN CASH_APPLICATIONS ca
    ON ca.invoice_id = i.invoice_id
JOIN PAYMENTS p
    ON p.payment_id = ca.payment_id
ORDER BY days_to_pay DESC;


Průměrná doba zaplacení
SELECT
    ROUND(AVG(julianday(p.payment_date) - julianday(i.invoice_date)), 2) AS avg_days_to_pay
FROM INVOICES i
JOIN CASH_APPLICATIONS ca
    ON ca.invoice_id = i.invoice_id
JOIN PAYMENTS p
    ON p.payment_id = ca.payment_id;


On-time vs late payments
SELECT
    i.invoice_id,
    i.due_date,
    p.payment_date,
    CASE
        WHEN p.payment_date > i.due_date THEN 'LATE'
        ELSE 'ON_TIME'
    END AS payment_status
FROM INVOICES i
JOIN CASH_APPLICATIONS ca
    ON ca.invoice_id = i.invoice_id
JOIN PAYMENTS p
    ON p.payment_id = ca.payment_id
ORDER BY i.invoice_id;

Souhrn late vs on-time
SELECT
    CASE
        WHEN p.payment_date > i.due_date THEN 'LATE'
        ELSE 'ON_TIME'
    END AS payment_status,
    COUNT(*) AS payment_count
FROM INVOICES i
JOIN CASH_APPLICATIONS ca
    ON ca.invoice_id = i.invoice_id
JOIN PAYMENTS p
    ON p.payment_id = ca.payment_id
GROUP BY payment_status;


Late vs on-time podle zákazníka
SELECT
    c.customer_name,
    CASE
        WHEN p.payment_date > i.due_date THEN 'LATE'
        ELSE 'ON_TIME'
    END AS payment_status,
    COUNT(*) AS payment_count
FROM INVOICES i
JOIN CUSTOMERS c
    ON c.customer_id = i.customer_id
JOIN CASH_APPLICATIONS ca
    ON ca.invoice_id = i.invoice_id
JOIN PAYMENTS p
    ON p.payment_id = ca.payment_id
GROUP BY c.customer_name, payment_status
ORDER BY c.customer_name, payment_count DESC;


Top 5 nejpomaleji zaplacených faktur
