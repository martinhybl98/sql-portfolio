    i.invoice_id,
    c.customer_name,
    i.invoice_date,
    p.payment_date,
    CAST(julianday(p.payment_date) - julianday(i.invoice_date) AS INTEGER) AS days_to_pay
FROM INVOICES i
JOIN CUSTOMERS c
